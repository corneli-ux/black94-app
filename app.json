{
  "expo": {
    "name": "Black94",
    "slug": "black94",
    "version": "1.8.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.black94.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.black94.app",
      "googleServicesFile": "./google-services.json",
      "versionCode": 12,
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "CAMERA"
      ],
      "softwareKeyboardLayoutMode": "resize",
      "splash": {
        "backgroundColor": "#000000",
        "resizeMode": "contain",
        "androidWindowSplashScreenBackgroundColor": "#000000",
        "androidWindowSplashScreenAnimatedIcon": "./assets/splash-icon.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.210565807767-jtedotfd6hqn8cn31meuk2cfp2dkm88o"
        }
      ]
    ],
    "extra": {
      "eas": {
