rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ── Privilege escalation helpers ──────────────────────────────────
    // These compare the EXISTING doc (resource.data) against the NEW doc
    // (request.resource.data) to detect when a user is trying to GRANT
    // themselves a privilege they didn't have before.
    //
    // IMPORTANT: The previous rule used `request.resource.data.isVerified != true`
    // which blocks ALL updates for users who ALREADY have isVerified=true,
    // because the new doc state still contains isVerified=true. This made it
    // impossible for verified users (or premium/business users with gold/blue
    // badge) to edit their bio, avatar, or display name.
    //
    // The fix: only block ESCALATION (false→true), not the existing state.

    function isEscalatingBool(field) {
      // True if the field is going from non-true to true
      return resource.data.get(field, false) != true
        && request.resource.data.get(field, false) == true;
    }

    function hasPrivilegedBadge(data) {
      return data.get('badge', '') in ['gold', 'blue', 'pro'];
    }

    function isAdminRole(data) {
      return data.get('role', 'personal') == 'admin';
    }

    function isEscalatingBadge() {
      // True if badge is being escalated to a privileged value
      return hasPrivilegedBadge(request.resource.data)
        && !hasPrivilegedBadge(resource.data);
    }

    function isEscalatingRole() {
      // True if role is being escalated to admin
      return isAdminRole(request.resource.data)
        && !isAdminRole(resource.data);
    }

    // ── Users ──────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if true;
      // Create: new users cannot grant themselves privileges
      allow create: if isAuthenticated()
        && request.resource.data.get('isAdmin', false) != true
        && request.resource.data.get('isVerified', false) != true
        && !hasPrivilegedBadge(request.resource.data)
        && !isAdminRole(request.resource.data);
      // Update: owner can update any field, but cannot ESCALATE privileges.
      // This allows verified/premium/business users to edit their bio,
      // avatar, display name, etc. without losing their existing status.
      allow update: if isOwner(userId)
        && !isEscalatingBool('isAdmin')
        && !isEscalatingBool('isVerified')
        && !isEscalatingBadge()
        && !isEscalatingRole();
      allow delete: if isOwner(userId);
    }

    // ── Usernames ──────────────────────────────────────────────────────
    // IMPORTANT: delete was previously `isAuthenticated()` which allowed
    // ANY authenticated user to delete ANY username doc (stealing usernames).
    // Now only the owner of the username can delete it.
    match /usernames/{username} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
        && get(/databases/$(database)/documents/usernames/$(username)).data.uid == request.auth.uid;
      allow delete: if isAuthenticated()
        && get(/databases/$(database)/documents/usernames/$(username)).data.uid == request.auth.uid;
    }

    // ── Posts ──────────────────────────────────────────────────────────
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.authorId == request.auth.uid
        || request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['likeCount','repostCount','commentCount','viewCount','bookmarkCount'])
      );
      allow delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;
    }

    // ── Post interactions ──────────────────────────────────────────────
    match /post_likes/{likeId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated();
      allow update: if false;
    }
    match /post_bookmarks/{bookmarkId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated();
      allow update: if false;
    }
    match /post_reposts/{repostId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated();
      allow update: if false;
    }
    match /post_comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    match /post_comments/{commentId}/{sub}/{subId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated();
      allow update: if false;
    }
    match /posts/{postId}/poll_votes/{voteId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if false;
    }

    // ── Stories ────────────────────────────────────────────────────────
    match /stories/{storyId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    match /stories/{storyId}/votes/{voteId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if false;
    }
    match /story_comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ── Chats ──────────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    match /chats/{chatId}/messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ── Notifications ──────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ── Follows & Blocks ───────────────────────────────────────────────
    match /follows/{followId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated();
      allow update: if false;
    }
    match /blocks/{blockId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated();
      allow update: if false;
    }
    match /blockedBy/{blockId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── Generic interactions ───────────────────────────────────────────
    match /likes/{likeId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated();
      allow update: if false;
    }
    match /reposts/{repostId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated();
      allow update: if false;
    }
    match /bookmarks/{bookmarkId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated();
      allow update: if false;
    }
    match /saved/{savedId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated();
      allow update: if false;
    }
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ── Anonymous chat ─────────────────────────────────────────────────
    match /anonRooms/{roomId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }
    match /anonRooms/{roomId}/anonMessages/{msgId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if false;
    }
    match /anonQueue/{queueId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if false;
    }

    // ── Voice calls ────────────────────────────────────────────────────
    match /calls/{callId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ── Push tokens ────────────────────────────────────────────────────
    match /user_push_tokens/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }
    match /user_push_tokens/{userId}/tokens/{tokenId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // ── Everything else: authenticated users can read/write ────────────
    match /{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
