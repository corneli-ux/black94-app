rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: authenticated user
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper: user is the owner of the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      allow read: if true; // Anyone can read user profiles
      allow create: if isAuthenticated(); // Can create own profile on signup
      allow update: if isOwner(userId); // Only owner can update
      allow delete: if isOwner(userId);
    }

    // Posts collection
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated(); // Allow likes, comments count updates from any signed-in user
      allow delete: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
    }

    // Messages (subcollection under chats)
    match /chats/{chatId}/messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if false;
    }

    // Chats collection
    match /chats/{chatId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // Stories collection
    match /stories/{storyId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // Comments collection
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
    }

    // Likes collection
    match /likes/{likeId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated();
      allow update: if false;
    }

    // Subscriptions collection
    match /subscriptions/{subId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    // Notifications collection
    match /notifications/{notifId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // Blocks collection
    match /blocks/{blockId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated();
      allow update: if false;
    }

    // Follows collection
    match /follows/{followId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated();
      allow update: if false;
    }

    // Orders collection
    match /orders/{orderId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    // Products collection
    match /products/{productId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // CRM leads collection
    match /crm_leads/{leadId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // Paid chat access
    match /paid_chat_access/{accessId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    // Chat payments
    match /chat_payments/{paymentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    // Reports
    match /reports/{reportId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    // Saved posts
    match /saved/{savedId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated();
      allow update: if false;
    }

    // Feed / recommendations
    match /feed/{feedId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
