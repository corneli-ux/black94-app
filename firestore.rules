rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ── Users ──────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if true;
      allow create: if isAuthenticated();
      // Users can update their own profile.
      // They cannot grant themselves admin, verified status, or elevated badges.
      // Only backend/Cloud Functions can set isVerified=true, isAdmin=true, badge=gold/blue/pro.
      allow update: if isOwner(userId)
        && request.resource.data.isAdmin != true
        && request.resource.data.isVerified != true
        && !(request.resource.data.get('badge', '') in ['gold', 'blue', 'pro'])
        && !(request.resource.data.get('role', 'personal') in ['admin']);
      allow delete: if isOwner(userId);
    }

    // ── Usernames ──────────────────────────────────────────────────────
    match /usernames/{username} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
        && get(/databases/$(database)/documents/usernames/$(username)).data.uid == request.auth.uid;
      allow delete: if isAuthenticated();
    }

    // ── Posts ──────────────────────────────────────────────────────────
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.authorId == request.auth.uid
        || request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['likeCount','repostCount','commentCount','viewCount','bookmarkCount'])
      );
      allow delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;
    }

    // ── Post interactions ──────────────────────────────────────────────
    match /post_likes/{likeId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated();
      allow update: if false;
    }
    match /post_bookmarks/{bookmarkId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated();
      allow update: if false;
    }
    match /post_reposts/{repostId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated();
      allow update: if false;
    }
    match /post_comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    match /post_comments/{commentId}/{sub}/{subId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated();
      allow update: if false;
    }
    match /posts/{postId}/poll_votes/{voteId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if false;
    }

    // ── Stories ────────────────────────────────────────────────────────
    match /stories/{storyId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    match /stories/{storyId}/votes/{voteId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if false;
    }
    match /story_comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ── Chats ──────────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    match /chats/{chatId}/messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ── Notifications ──────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ── Follows & Blocks ───────────────────────────────────────────────
    match /follows/{followId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated();
      allow update: if false;
    }
    match /blocks/{blockId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated();
      allow update: if false;
    }
    match /blockedBy/{blockId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── Generic interactions ───────────────────────────────────────────
    match /likes/{likeId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated();
      allow update: if false;
    }
    match /reposts/{repostId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated();
      allow update: if false;
    }
    match /bookmarks/{bookmarkId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated();
      allow update: if false;
    }
    match /saved/{savedId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated();
      allow update: if false;
    }
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ── Anonymous chat ─────────────────────────────────────────────────
    match /anonRooms/{roomId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }
    match /anonRooms/{roomId}/anonMessages/{msgId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if false;
    }
    match /anonQueue/{queueId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if false;
    }

    // ── Voice calls ────────────────────────────────────────────────────
    match /calls/{callId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ── Push tokens ────────────────────────────────────────────────────
    match /user_push_tokens/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }
    match /user_push_tokens/{userId}/tokens/{tokenId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // ── Everything else: authenticated users can read/write ────────────
    match /{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
