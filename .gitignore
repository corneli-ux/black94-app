# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Functions compiled output
functions/lib/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Signing keys
!keystore/release.keystore (NEVER commit these)
*.keystore
/android/app/release.keystore

# Firebase config — stored as GitHub Secret, decoded at build time
/google-services.json
/GoogleService-Info.plist

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env.*
.env*.local
!.env.example

# typescript
*.tsbuildinfo

# generated native folders (EAS Build runs expo prebuild automatically)
/android
/ios

# Android build artifacts (source is committed, outputs are not)
/android/app/build
/android/build
/android/.gradle
/android/.cxx
/android/local.properties

# Android Studio
.idea/
*.iml

# Build outputs (APK, AAB, ZIP — never commit these)
/download/
*.apk
*.aab
*.zip

# Secrets scripts (never commit these)
_set_secret.py

# Temp scripts
SUBMIT_ME.sh
new.sh
new2.sh
new3.sh
android/keystore/
.dev-notes/
